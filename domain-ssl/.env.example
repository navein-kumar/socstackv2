# ============================================================
# SOC STACK - Environment Configuration Template
# ============================================================
# Copy this to .env and fill in your values:
#   cp .env.example .env
#   nano .env
#
# REQUIRED fields are marked [REQUIRED]
# AUTO-GENERATED fields are populated by post-deploy.py
# ============================================================

# === SERVER [REQUIRED] ===
SERVER_IP=YOUR_SERVER_IP
# DEPLOY_DIR — auto-detected (no need to set).
# Both pre-deploy.sh and post-deploy.py detect the deploy folder automatically.

# === DOMAIN CONFIGURATION [REQUIRED] ===
# All domains must have DNS A records pointing to SERVER_IP
# Run pre-deploy.sh to verify DNS before deploying
SSO_DOMAIN=sso.yourdomain.com
WAZUH_DOMAIN=wazuh.yourdomain.com
N8N_DOMAIN=n8n.yourdomain.com
MISP_DOMAIN=cti.yourdomain.com
THEHIVE_DOMAIN=hive.yourdomain.com
CORTEX_DOMAIN=cortex.yourdomain.com
NPM_DOMAIN=npm.yourdomain.com

# === NGINX PROXY MANAGER ===
NPM_ADMIN_EMAIL=admin@yourdomain.com
NPM_ADMIN_PASSWORD=ChangeMe_Npm@2025

# === KEYCLOAK SSO ===
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=ChangeMe_Keycloak@2025
# KC_DB_PASSWORD is hardcoded in docker-compose.yml (internal backend, never changes)

# === WAZUH ===
WAZUH_VERSION=4.14.3
WAZUH_INDEXER_USERNAME=admin
WAZUH_INDEXER_PASSWORD=ChangeMe_SecretPassword
WAZUH_API_USER=wazuh-wui
WAZUH_API_PASSWORD=ChangeMe_WazuhApi@2025
WAZUH_DASHBOARD_USER=kibanaserver
WAZUH_DASHBOARD_PASSWORD=kibanaserver

# === N8N ===
N8N_ADMIN_EMAIL=admin@yourdomain.com
N8N_ADMIN_PASSWORD=ChangeMe_N8n@2025

# === MISP ===
MISP_ADMIN_EMAIL=admin@yourdomain.com
MISP_ADMIN_PASSWORD=ChangeMe_Misp@2025
MISP_ORG=YOURORG
# MISP_REDIS_PASSWORD, MISP_DB_USER/PASSWORD/ROOT_PASSWORD are hardcoded in docker-compose.yml (internal backend)

# === THEHIVE ===
THEHIVE_SECRET=ChangeMe_TheHive2025SecretKey
THEHIVE_ADMIN_USER=admin@thehive.local
THEHIVE_ADMIN_PASSWORD=ChangeMe_TheHive@2025
THEHIVE_DEFAULT_PASSWORD=secret
THEHIVE_ORG_NAME=YOURORG
THEHIVE_ORG_DESC=Your SOC Organization
THEHIVE_ANALYST_USER=analyst@yourdomain.com
THEHIVE_ANALYST_PASSWORD=ChangeMe_Analyst@2025

# === CORTEX ===
CORTEX_SECRET=ChangeMe_Cortex2025SecretKey
CORTEX_ADMIN_USER=admin@yourdomain.com
CORTEX_ADMIN_PASSWORD=ChangeMe_Cortex@2025
CORTEX_ORG_NAME=yourorg
CORTEX_ORG_ADMIN=orgadmin@yourdomain.com
# CORTEX_API_KEY → AUTO-GENERATED by post-deploy.py

# MINIO_ROOT_USER/PASSWORD are hardcoded in docker-compose.yml (internal backend)

# === KEYCLOAK SSO ===
KC_WAZUH_REALM=SOC
KC_WAZUH_CLIENT_ID=soc-sso
# SSO_CLIENT_SECRET → AUTO-GENERATED by post-deploy.py (Keycloak client secret)
# OAUTH2_PROXY_COOKIE_SECRET → AUTO-GENERATED by post-deploy.py (32-byte random)

# SSO Users (created in Keycloak by post-deploy.py)
SSO_ADMIN_EMAIL=admin@yourdomain.com
SSO_ADMIN_PASSWORD=ChangeMe_SsoAdmin@2025
SSO_ADMIN_FIRST=SOC
SSO_ADMIN_LAST=Admin
SSO_ANALYST_EMAIL=analyst@yourdomain.com
SSO_ANALYST_PASSWORD=ChangeMe_SsoAnalyst@2025
SSO_ANALYST_FIRST=SOC
SSO_ANALYST_LAST=Analyst
SSO_READONLY_EMAIL=readonly@yourdomain.com
SSO_READONLY_PASSWORD=ChangeMe_SsoReadonly@2025
SSO_READONLY_FIRST=SOC
SSO_READONLY_LAST=Readonly

# === MISP-THEHIVE INTEGRATION ===
# MISP_API_KEY → AUTO-GENERATED (retrieved by post-deploy.py)
